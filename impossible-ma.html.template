<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>ImpossibleMA — Synthesize the previously unsynthesizable</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 0; }
    #splash { position: fixed; inset: 0; background: #111; color: #eee;
              display: flex; flex-direction: column; align-items: center;
              justify-content: center; z-index: 1000; font-family: monospace; }
    #splash h1 { font-size: 1.8rem; margin-bottom: 1rem; }
    #splash p { margin: 0.3rem; }
    #app { display: none; padding: 1rem 2rem; max-width: 1200px; margin: 0 auto; }
    #app.ready { display: block; }
    header { border-bottom: 1px solid #ddd; padding-bottom: 0.5rem; }
    header nav { display: flex; gap: 1rem; margin-top: 0.5rem; }
    header nav a { padding: 0.4rem 0.8rem; border: 1px solid #ccc;
                   border-radius: 4px; text-decoration: none; color: #333; }
    header nav a.active { background: #333; color: #fff; }
    .tab-pane { display: none; padding: 1rem 0; }
    .tab-pane.active { display: block; }
    footer { border-top: 1px solid #ddd; padding-top: 0.5rem; margin-top: 2rem; font-size: 0.85rem; }
    footer input { font-family: monospace; width: 32em; }
    fieldset { margin: 0.8rem 0; padding: 0.5rem 1rem; }
    fieldset label { display: inline-block; margin-right: 1rem; }
    .row { display: flex; gap: 0.5rem; align-items: center; }
    .error { color: #b00; background: #fee; padding: 0.5rem; border-radius: 4px; margin: 0.5rem 0; }
    table { border-collapse: collapse; }
    th, td { padding: 0.2rem 0.4rem; border: 1px solid #ddd; }
    input[type="number"] { width: 8em; }
    input[type="text"] { width: 8em; }
    button:disabled { opacity: 0.5; }
  </style>
  <script src="https://cdn.jsdelivr.net/pyodide/v0.27.7/full/pyodide.js"></script>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <script id="impossible-ma-wheel" type="application/octet-stream">__WHEEL_BASE64__</script>
</head>
<body>
  <div id="splash">
    <h1>ImpossibleMA</h1>
    <p id="splash-status">Loading Python runtime (~6 MB)...</p>
  </div>
  <div id="app">
    <header>
      <h1>ImpossibleMA <small>v0.1</small></h1>
      <nav id="tabs">
        <a href="#k1" data-tab="k1">k=1 (single-study)</a>
        <a href="#missing_se" data-tab="missing_se">missing_se</a>
        <a href="#adversarial" data-tab="adversarial">adversarial</a>
      </nav>
    </header>
    <main>
      <section class="tab-pane" data-pane="k1">
        <h2>k=1 - single-study borrowing</h2>
        <div class="row">
          <label>Built-in dataset:
            <select id="k1-dataset">
              <option value="">-- choose --</option>
              <option value="rare_hf">Rare-disease HF trial</option>
              <option value="novel_device">Novel-device pivotal</option>
              <option value="single_arm_oncology">Single-arm oncology</option>
            </select>
          </label>
          <button id="k1-load">Load</button>
        </div>
        <fieldset>
          <legend>Target trial</legend>
          <label>Estimate (log scale): <input type="number" step="0.01" id="k1-target-est" /></label>
          <label>SE: <input type="number" step="0.01" id="k1-target-se" /></label>
          <label>Endpoint:
            <select id="k1-endpoint">
              <option value="binary">binary (log-OR)</option>
              <option value="continuous">continuous (SMD)</option>
              <option value="tte">time-to-event (log-HR)</option>
            </select>
          </label>
        </fieldset>
        <fieldset>
          <legend>Adjacent trials (>=3)</legend>
          <table id="k1-adjacent">
            <thead><tr><th>Study</th><th>Estimate</th><th>SE</th><th></th></tr></thead>
            <tbody></tbody>
          </table>
          <button id="k1-add-row">+ Add row</button>
        </fieldset>
        <button id="k1-run" disabled>Run k=1</button>
        <div id="k1-error" class="error" hidden></div>
        <div id="k1-result" hidden>
          <h3>Envelope</h3>
          <div id="k1-viz"></div>
          <details><summary>Raw JSON</summary><pre id="k1-json"></pre></details>
          <button id="k1-export-json">Download signed JSON</button>
          <button id="k1-export-report">Printable report</button>
        </div>
      </section>
      <section class="tab-pane" data-pane="missing_se">
        <h2>missing_se - SE reconstruction</h2>
        <div class="row">
          <label>Built-in dataset:
            <select id="ms-dataset">
              <option value="">-- choose --</option>
              <option value="figure_only">Figure-only legacy trial (effect + CI)</option>
              <option value="p_only">p-only abstract (effect + p)</option>
              <option value="multi_consistent">Multi-route consistent</option>
            </select>
          </label>
          <button id="ms-load">Load</button>
        </div>
        <fieldset>
          <legend>Inputs</legend>
          <label>Effect: <input type="number" step="0.01" id="ms-effect" /></label>
          <label>p-value: <input type="number" step="0.001" id="ms-p" /></label>
          <label>CI lower: <input type="number" step="0.01" id="ms-ci-lo" /></label>
          <label>CI upper: <input type="number" step="0.01" id="ms-ci-hi" /></label>
          <label>Statistic: <input type="number" step="0.01" id="ms-stat" /></label>
          <label>df: <input type="number" step="1" id="ms-df" /></label>
        </fieldset>
        <button id="ms-run" disabled>Run missing_se</button>
        <div id="ms-error" class="error" hidden></div>
        <div id="ms-result" hidden>
          <h3>Envelope</h3>
          <div id="ms-viz"></div>
          <details><summary>Raw JSON</summary><pre id="ms-json"></pre></details>
          <button id="ms-export-json">Download signed JSON</button>
          <button id="ms-export-report">Printable report</button>
        </div>
      </section>
      <section class="tab-pane" data-pane="adversarial">
        <h2>adversarial - worst/best defensible pool</h2>
        <div class="row">
          <label>Built-in dataset:
            <select id="adv-dataset">
              <option value="">-- choose --</option>
              <option value="pcsk9">PCSK9 inhibitors (12 studies)</option>
              <option value="ace_legacy">Legacy ACE-I question (18 studies)</option>
              <option value="covid_early">COVID early treatment (14 studies)</option>
            </select>
          </label>
          <button id="adv-load">Load</button>
          <span> or </span>
          <label>CSV upload: <input type="file" id="adv-csv" accept=".csv" /></label>
        </div>
        <fieldset>
          <legend>Studies (&gt;=3 needed; columns: study, estimate, se, rob, n, followup, language, pub_type)</legend>
          <table id="adv-studies">
            <thead><tr>
              <th>study</th><th>estimate</th><th>se</th><th>rob</th>
              <th>n</th><th>followup</th><th>language</th><th>pub_type</th><th></th>
            </tr></thead>
            <tbody></tbody>
          </table>
          <button id="adv-add-row">+ Add row</button>
        </fieldset>
        <button id="adv-run" disabled>Run adversarial</button>
        <div id="adv-error" class="error" hidden></div>
        <div id="adv-result" hidden>
          <h3>Envelope</h3>
          <div id="adv-viz"></div>
          <details><summary>Raw JSON</summary><pre id="adv-json"></pre></details>
          <button id="adv-export-json">Download signed JSON</button>
          <button id="adv-export-report">Printable report</button>
        </div>
      </section>
    </main>
    <footer id="footer">
      <label>TruthCert key (32+ chars, sessionStorage):
        <input type="password" id="truthcert-key" minlength="32" />
      </label>
    </footer>
  </div>
  <script>
    const status = (msg) => { document.getElementById('splash-status').textContent = msg; };

    async function bootstrap() {
      try {
        status('Loading Python runtime (~6 MB)...');
        const pyodide = await loadPyodide({ indexURL: 'https://cdn.jsdelivr.net/pyodide/v0.27.7/full/' });

        status('Installing scipy + numpy + pandas (~40 MB)...');
        await pyodide.loadPackage(['scipy', 'numpy', 'pandas']);

        status('Installing micropip...');
        await pyodide.loadPackage('micropip');

        status('Installing ImpossibleMA engine...');
        const wheelB64 = document.getElementById('impossible-ma-wheel').textContent;
        const wheelBytes = Uint8Array.from(atob(wheelB64), c => c.charCodeAt(0));
        // micropip parses the wheel filename, so it must include version tags.
        const wheelFilename = '/tmp/impossible_ma-0.1.0-py3-none-any.whl';
        pyodide.FS.writeFile(wheelFilename, wheelBytes);
        pyodide.globals.set('WHEEL_PATH', wheelFilename);
        await pyodide.runPythonAsync(`
import micropip
await micropip.install('emfs:' + WHEEL_PATH)
import impossible_ma
print('ImpossibleMA loaded:', impossible_ma.__version__)
        `);

        window.PYODIDE = pyodide;
        window.PYODIDE_READY = true;
        document.getElementById('splash').style.display = 'none';
        document.getElementById('app').classList.add('ready');
      } catch (err) {
        status('Load failed: ' + err.message);
        window.PYODIDE_LOAD_ERROR = String(err);
      }
    }
    function syncTabs() {
      const hash = location.hash.replace('#', '') || 'k1';
      for (const link of document.querySelectorAll('#tabs a')) {
        link.classList.toggle('active', link.dataset.tab === hash);
      }
      for (const pane of document.querySelectorAll('.tab-pane')) {
        pane.classList.toggle('active', pane.dataset.pane === hash);
      }
    }
    window.addEventListener('hashchange', syncTabs);
    window.addEventListener('DOMContentLoaded', syncTabs);

    const keyInput = document.getElementById('truthcert-key');
    if (keyInput) {
      keyInput.value = sessionStorage.getItem('truthcert_key') || '';
      keyInput.addEventListener('input', () => {
        sessionStorage.setItem('truthcert_key', keyInput.value);
      });
    }

    // ---- k=1 tab ----
    const BUILTIN_K1 = {
      rare_hf: {
        target_estimate: -0.42, target_se: 0.31, endpoint: 'binary',
        adjacent: [
          ['HF-A', -0.30, 0.15], ['HF-B', -0.25, 0.12],
          ['HF-C', -0.40, 0.18], ['HF-D', -0.20, 0.20], ['HF-E', -0.35, 0.10],
        ],
      },
      novel_device: {
        target_estimate: -0.55, target_se: 0.28, endpoint: 'binary',
        adjacent: [
          ['DEV-X1', -0.35, 0.18], ['DEV-X2', -0.50, 0.15],
          ['DEV-X3', -0.45, 0.20], ['DEV-X4', -0.60, 0.22],
        ],
      },
      single_arm_oncology: {
        target_estimate: 0.62, target_se: 0.30, endpoint: 'continuous',
        adjacent: [
          ['ONC-1', 0.55, 0.20], ['ONC-2', 0.70, 0.18], ['ONC-3', 0.50, 0.25],
        ],
      },
    };

    function k1AddRow(study = '', est = '', se = '') {
      const tbody = document.querySelector('#k1-adjacent tbody');
      const tr = document.createElement('tr');
      tr.innerHTML =
        '<td><input type="text" class="k1-study" value="' + study + '" /></td>' +
        '<td><input type="number" step="0.01" class="k1-est" value="' + est + '" /></td>' +
        '<td><input type="number" step="0.01" class="k1-se"  value="' + se + '" /></td>' +
        '<td><button class="k1-row-del">x</button></td>';
      tr.querySelector('.k1-row-del').addEventListener('click', () => {
        tr.remove(); k1ValidateRunButton();
      });
      for (const inp of tr.querySelectorAll('input')) {
        inp.addEventListener('input', k1ValidateRunButton);
      }
      tbody.appendChild(tr);
      k1ValidateRunButton();
    }

    function k1LoadDataset(name) {
      const d = BUILTIN_K1[name];
      if (!d) return;
      document.getElementById('k1-target-est').value = d.target_estimate;
      document.getElementById('k1-target-se').value = d.target_se;
      document.getElementById('k1-endpoint').value = d.endpoint;
      document.querySelector('#k1-adjacent tbody').innerHTML = '';
      for (const [study, est, se] of d.adjacent) k1AddRow(study, est, se);
    }

    function k1ReadInputs() {
      const target_estimate = parseFloat(document.getElementById('k1-target-est').value);
      const target_se = parseFloat(document.getElementById('k1-target-se').value);
      const endpoint = document.getElementById('k1-endpoint').value;
      const adjacent = [];
      for (const tr of document.querySelectorAll('#k1-adjacent tbody tr')) {
        const e = parseFloat(tr.querySelector('.k1-est').value);
        const s = parseFloat(tr.querySelector('.k1-se').value);
        if (Number.isFinite(e) && Number.isFinite(s)) adjacent.push([e, s]);
      }
      return { target_estimate, target_se, endpoint, adjacent };
    }

    function k1ValidateRunButton() {
      const inp = k1ReadInputs();
      const ok = Number.isFinite(inp.target_estimate)
              && Number.isFinite(inp.target_se) && inp.target_se > 0
              && inp.adjacent.length >= 3;
      document.getElementById('k1-run').disabled = !ok;
    }

    document.getElementById('k1-load').addEventListener('click', () => {
      const name = document.getElementById('k1-dataset').value;
      if (name) k1LoadDataset(name);
    });
    document.getElementById('k1-add-row').addEventListener('click', () => k1AddRow());
    window.addEventListener('DOMContentLoaded', () => {
      k1AddRow(); k1AddRow(); k1AddRow();
    });

    async function k1Run() {
      const errBox = document.getElementById('k1-error');
      const result = document.getElementById('k1-result');
      errBox.hidden = true; result.hidden = true;
      if (!window.PYODIDE_READY) {
        errBox.textContent = 'Engine not ready yet.'; errBox.hidden = false; return;
      }
      const inp = k1ReadInputs();
      try {
        window.PYODIDE.globals.set('K1_INPUT', window.PYODIDE.toPy(inp));
        const result_json = await window.PYODIDE.runPythonAsync(`
import json
from impossible_ma.kone import KoneInput, kone_envelope
from dataclasses import asdict
_inp = K1_INPUT.to_py()
inp = KoneInput(
    target_estimate=_inp['target_estimate'],
    target_se=_inp['target_se'],
    adjacent=[tuple(a) for a in _inp['adjacent']],
    endpoint=_inp['endpoint'],
)
env = kone_envelope(inp)
json.dumps(asdict(env), default=float)
        `);
        const env = JSON.parse(result_json);
        document.getElementById('k1-json').textContent = JSON.stringify(env, null, 2);
        window.K1_LAST_ENVELOPE = env;
        document.getElementById('k1-result').hidden = false;
        k1Render(env);
      } catch (err) {
        errBox.textContent = 'Error: ' + (err.message || String(err));
        errBox.hidden = false;
      }
    }

    function k1Render(env) {
      const cs = env.case_specific;
      const xs = [];
      const lo = Math.min(cs.vague_ci[0], cs.full_borrowing_ci[0], env.lower) - 0.2;
      const hi = Math.max(cs.vague_ci[1], cs.full_borrowing_ci[1], env.upper) + 0.2;
      for (let i = 0; i <= 200; i++) xs.push(lo + (hi - lo) * i / 200);
      const normPdf = (x, mu, sd) =>
        Math.exp(-0.5 * ((x - mu) / sd) ** 2) / (sd * Math.sqrt(2 * Math.PI));
      const target_se = (cs.vague_ci[1] - cs.vague_ci[0]) / (2 * 1.96);
      const target_mu = (cs.vague_ci[0] + cs.vague_ci[1]) / 2;
      const full_se = (cs.full_borrowing_ci[1] - cs.full_borrowing_ci[0]) / (2 * 1.96);
      const full_mu = (cs.full_borrowing_ci[0] + cs.full_borrowing_ci[1]) / 2;
      const traces = [
        { x: xs, y: xs.map(x => normPdf(x, target_mu, target_se)),
          name: 'Vague (target alone)', mode: 'lines', line: { color: '#888' } },
        { x: xs, y: xs.map(x => normPdf(x, full_mu, full_se)),
          name: 'Full borrowing', mode: 'lines', line: { color: '#06c' } },
        { x: [env.lower, env.upper], y: [0, 0],
          name: 'Envelope', mode: 'lines+markers',
          line: { color: '#000', width: 4 }, marker: { size: 10 } },
        { x: [env.point], y: [0], name: 'Robust point',
          mode: 'markers', marker: { size: 14, color: '#c00', symbol: 'diamond' } },
      ];
      Plotly.newPlot('k1-viz', traces, {
        margin: { t: 20, b: 40 }, height: 360,
        xaxis: { title: 'Effect (log scale)' }, yaxis: { title: 'Density' },
      }, { displayModeBar: false });
    }

    document.getElementById('k1-run').addEventListener('click', k1Run);

    // ---- missing_se tab ----
    const BUILTIN_MS = {
      figure_only:      { effect: 0.45, ci_lower: 0.10, ci_upper: 0.80 },
      p_only:           { effect: 0.30, p_value: 0.04 },
      multi_consistent: { effect: 0.40, p_value: 0.04, ci_lower: 0.0, ci_upper: 0.80, statistic: 2.0 },
    };

    function msReadInputs() {
      const num = (id) => {
        const v = parseFloat(document.getElementById(id).value);
        return Number.isFinite(v) ? v : null;
      };
      const intOrNull = (id) => {
        const v = parseInt(document.getElementById(id).value, 10);
        return Number.isFinite(v) ? v : null;
      };
      return {
        effect: num('ms-effect'),
        p_value: num('ms-p'),
        ci_lower: num('ms-ci-lo'),
        ci_upper: num('ms-ci-hi'),
        statistic: num('ms-stat'),
        df: intOrNull('ms-df'),
      };
    }

    function msLoadDataset(name) {
      const d = BUILTIN_MS[name];
      if (!d) return;
      ['ms-effect','ms-p','ms-ci-lo','ms-ci-hi','ms-stat','ms-df']
        .forEach(id => document.getElementById(id).value = '');
      if (d.effect != null) document.getElementById('ms-effect').value = d.effect;
      if (d.p_value != null) document.getElementById('ms-p').value = d.p_value;
      if (d.ci_lower != null) document.getElementById('ms-ci-lo').value = d.ci_lower;
      if (d.ci_upper != null) document.getElementById('ms-ci-hi').value = d.ci_upper;
      if (d.statistic != null) document.getElementById('ms-stat').value = d.statistic;
      msValidateRun();
    }

    function msValidateRun() {
      const inp = msReadInputs();
      const hasRoute = inp.p_value != null
                    || (inp.ci_lower != null && inp.ci_upper != null)
                    || inp.statistic != null;
      document.getElementById('ms-run').disabled = !(inp.effect != null && hasRoute);
    }

    async function msRun() {
      const errBox = document.getElementById('ms-error');
      const result = document.getElementById('ms-result');
      errBox.hidden = true; result.hidden = true;
      if (!window.PYODIDE_READY) {
        errBox.textContent = 'Engine not ready yet.'; errBox.hidden = false; return;
      }
      const inp = msReadInputs();
      const py_kwargs = Object.fromEntries(
        Object.entries(inp).filter(([_, v]) => v !== null)
      );
      try {
        window.PYODIDE.globals.set('MS_KW', window.PYODIDE.toPy(py_kwargs));
        const result_json = await window.PYODIDE.runPythonAsync(`
import json
from impossible_ma.missing_se import MissingSeInput, missing_se_envelope
from dataclasses import asdict
inp = MissingSeInput(**MS_KW.to_py())
env = missing_se_envelope(inp)
json.dumps(asdict(env), default=float)
        `);
        const env = JSON.parse(result_json);
        document.getElementById('ms-json').textContent = JSON.stringify(env, null, 2);
        window.MS_LAST_ENVELOPE = env;
        document.getElementById('ms-result').hidden = false;
        msRender(env);
      } catch (err) {
        errBox.textContent = 'Error: ' + (err.message || String(err));
        errBox.hidden = false;
      }
    }

    function msRender(env) {
      const routes = env.case_specific.routes;
      const labels = Object.keys(routes);
      const values = Object.values(routes);
      const median = env.point;
      const traces = [{
        x: labels, y: values, type: 'bar',
        text: values.map(v => v.toFixed(4)), textposition: 'auto',
        marker: { color: '#06c' },
      }];
      if (median != null) {
        traces.push({
          x: labels, y: labels.map(() => median),
          mode: 'lines', name: 'Median (collapse point)',
          line: { color: '#c00', dash: 'dash' },
        });
      }
      Plotly.newPlot('ms-viz', traces, {
        margin: { t: 20, b: 50 }, height: 360,
        xaxis: { title: 'Reconstruction route' },
        yaxis: { title: 'Reconstructed SE' },
      }, { displayModeBar: false });
    }

    document.getElementById('ms-load').addEventListener('click', () => {
      const name = document.getElementById('ms-dataset').value;
      if (name) msLoadDataset(name);
    });
    ['ms-effect','ms-p','ms-ci-lo','ms-ci-hi','ms-stat','ms-df'].forEach(id => {
      document.getElementById(id).addEventListener('input', msValidateRun);
    });
    document.getElementById('ms-run').addEventListener('click', msRun);

    // ---- adversarial tab ----
    const BUILTIN_ADV = {
      pcsk9: [
        {study:'PCSK-1', estimate:-0.30, se:0.10, rob:'low',      n:300, followup:24, language:'english', pub_type:'peer'},
        {study:'PCSK-2', estimate:-0.25, se:0.12, rob:'low',      n:250, followup:18, language:'english', pub_type:'peer'},
        {study:'PCSK-3', estimate:-0.35, se:0.15, rob:'some',     n:180, followup:12, language:'english', pub_type:'peer'},
        {study:'PCSK-4', estimate:-0.40, se:0.18, rob:'moderate', n:120, followup:12, language:'english', pub_type:'peer'},
        {study:'PCSK-5', estimate:-0.20, se:0.20, rob:'high',     n: 80, followup: 6, language:'other',   pub_type:'peer'},
        {study:'PCSK-6', estimate:-0.45, se:0.22, rob:'some',     n:200, followup:24, language:'english', pub_type:'peer'},
        {study:'PCSK-7', estimate:-0.10, se:0.25, rob:'high',     n: 60, followup: 6, language:'english', pub_type:'grey'},
        {study:'PCSK-8', estimate:-0.55, se:0.14, rob:'low',      n:400, followup:36, language:'english', pub_type:'peer'},
        {study:'PCSK-9', estimate:-0.32, se:0.11, rob:'low',      n:350, followup:24, language:'english', pub_type:'peer'},
        {study:'PCSK-10',estimate:-0.28, se:0.13, rob:'some',     n:220, followup:18, language:'english', pub_type:'peer'},
        {study:'PCSK-11',estimate:-0.05, se:0.30, rob:'high',     n: 50, followup: 3, language:'other',   pub_type:'grey'},
        {study:'PCSK-12',estimate:-0.38, se:0.16, rob:'moderate', n:150, followup:12, language:'english', pub_type:'peer'},
      ],
      ace_legacy: Array.from({length: 18}, (_, i) => ({
        study: `ACE-${i+1}`,
        estimate: -0.25 + (i % 5) * 0.05 - (i % 3) * 0.04,
        se: 0.10 + (i % 4) * 0.04,
        rob: ['low','some','moderate','high'][i % 4],
        n: 100 + (i * 30) % 400,
        followup: [6, 12, 24, 36][i % 4],
        language: i % 7 === 0 ? 'other' : 'english',
        pub_type: i === 17 ? 'grey' : 'peer',
      })),
      covid_early: Array.from({length: 14}, (_, i) => ({
        study: `COV-${i+1}`,
        estimate: -0.10 + (i % 6) * 0.08 - 0.20,
        se: 0.12 + (i % 5) * 0.05,
        rob: ['low','some','moderate','high'][(i+1) % 4],
        n: 80 + (i * 25) % 300,
        followup: [3, 6, 12][i % 3],
        language: i % 6 === 0 ? 'other' : 'english',
        pub_type: (i % 8 === 0) ? 'grey' : 'peer',
      })),
    };

    const ADV_COLS = ['study','estimate','se','rob','n','followup','language','pub_type'];

    function advAddRow(row = {}) {
      const tbody = document.querySelector('#adv-studies tbody');
      const tr = document.createElement('tr');
      tr.innerHTML = ADV_COLS.map(c => {
        const v = row[c] != null ? row[c] : '';
        const type = ['estimate','se'].includes(c) ? 'number' :
                     (['n','followup'].includes(c) ? 'number' : 'text');
        const step = ['estimate','se'].includes(c) ? 'step="0.01"' : '';
        return `<td><input type="${type}" ${step} class="adv-${c}" value="${v}" /></td>`;
      }).join('') + `<td><button class="adv-row-del">x</button></td>`;
      tr.querySelector('.adv-row-del').addEventListener('click', () => { tr.remove(); advValidateRun(); });
      for (const inp of tr.querySelectorAll('input')) inp.addEventListener('input', advValidateRun);
      tbody.appendChild(tr);
      advValidateRun();
    }

    function advLoadDataset(name) {
      const rows = BUILTIN_ADV[name];
      if (!rows) return;
      document.querySelector('#adv-studies tbody').innerHTML = '';
      for (const r of rows) advAddRow(r);
    }

    function advReadStudies() {
      const studies = [];
      for (const tr of document.querySelectorAll('#adv-studies tbody tr')) {
        const obj = {};
        for (const c of ADV_COLS) {
          const v = tr.querySelector('.adv-' + c).value;
          if (['estimate','se'].includes(c)) obj[c] = parseFloat(v);
          else if (['n','followup'].includes(c)) obj[c] = parseInt(v, 10);
          else obj[c] = v;
        }
        studies.push(obj);
      }
      return studies;
    }

    function advValidateRun() {
      const studies = advReadStudies();
      const ok = studies.length >= 3 && studies.every(s =>
        Number.isFinite(s.estimate) && Number.isFinite(s.se) && s.se > 0
        && Number.isFinite(s.n) && Number.isFinite(s.followup)
        && s.rob && s.language && s.pub_type
      );
      document.getElementById('adv-run').disabled = !ok;
    }

    function advParseCsv(text) {
      const lines = text.trim().split(/\r?\n/);
      if (lines.length < 2) throw new Error('CSV has no data rows');
      const header = lines[0].split(',').map(h => h.trim());
      const missing = ADV_COLS.filter(c => !header.includes(c));
      if (missing.length) throw new Error('CSV missing columns: ' + missing.join(', '));
      const idx = ADV_COLS.map(c => header.indexOf(c));
      const rows = [];
      for (let i = 1; i < lines.length; i++) {
        const cells = lines[i].split(',').map(s => s.trim());
        const r = {};
        ADV_COLS.forEach((c, j) => {
          const v = cells[idx[j]];
          r[c] = ['estimate','se'].includes(c) ? parseFloat(v)
               : ['n','followup'].includes(c) ? parseInt(v, 10)
               : v;
        });
        rows.push(r);
      }
      return rows;
    }

    document.getElementById('adv-load').addEventListener('click', () => {
      const name = document.getElementById('adv-dataset').value;
      if (name) advLoadDataset(name);
    });
    document.getElementById('adv-add-row').addEventListener('click', () => advAddRow());
    document.getElementById('adv-csv').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const errBox = document.getElementById('adv-error');
      errBox.hidden = true;
      try {
        const text = await file.text();
        const rows = advParseCsv(text);
        document.querySelector('#adv-studies tbody').innerHTML = '';
        for (const r of rows) advAddRow(r);
      } catch (err) {
        errBox.textContent = err.message;
        errBox.hidden = false;
      }
    });
    window.addEventListener('DOMContentLoaded', () => {
      for (let i = 0; i < 3; i++) advAddRow();
    });

    async function advRun() {
      const errBox = document.getElementById('adv-error');
      const result = document.getElementById('adv-result');
      errBox.hidden = true; result.hidden = true;
      if (!window.PYODIDE_READY) {
        errBox.textContent = 'Engine not ready yet.'; errBox.hidden = false; return;
      }
      const studies = advReadStudies();
      try {
        window.PYODIDE.globals.set('ADV_STUDIES', window.PYODIDE.toPy(studies));
        const result_json = await window.PYODIDE.runPythonAsync(`
import json
import pandas as pd
from impossible_ma.adversarial import adversarial_envelope
from dataclasses import asdict
df = pd.DataFrame(ADV_STUDIES.to_py())
env = adversarial_envelope(df)
json.dumps(asdict(env), default=float)
        `);
        const env = JSON.parse(result_json);
        document.getElementById('adv-json').textContent = JSON.stringify(env, null, 2);
        window.ADV_LAST_ENVELOPE = env;
        document.getElementById('adv-result').hidden = false;
        advRender(env);
      } catch (err) {
        errBox.textContent = 'Error: ' + (err.message || String(err));
        errBox.hidden = false;
      }
    }

    function advRender(env) {
      const audit = env.case_specific.audit_trail || [];
      const estimates = audit.map(p => p.estimate);
      const full = env.case_specific.full_data_reml.estimate;
      const traces = [
        { x: estimates, type: 'histogram', name: 'Pool estimates',
          marker: { color: '#06c' }, opacity: 0.7, nbinsx: 40 },
        { x: [env.lower, env.lower], y: [0, 1], yref: 'paper',
          mode: 'lines', name: 'Envelope lower',
          line: { color: '#c00', width: 2 } },
        { x: [env.upper, env.upper], y: [0, 1], yref: 'paper',
          mode: 'lines', name: 'Envelope upper',
          line: { color: '#c00', width: 2 } },
        { x: [full, full], y: [0, 1], yref: 'paper',
          mode: 'lines', name: 'Full-data REML',
          line: { color: '#000', width: 2, dash: 'dash' } },
      ];
      const layout = {
        margin: { t: 60, b: 50 }, height: 420,
        title: `${env.case_specific.n_pools} pools | lower rule: ${env.case_specific.lower_rule}<br>upper rule: ${env.case_specific.upper_rule}`,
        xaxis: { title: 'Pooled estimate (log scale)' },
        yaxis: { title: 'Pool count' },
      };
      Plotly.newPlot('adv-viz', traces, layout, { displayModeBar: false });
    }

    document.getElementById('adv-run').addEventListener('click', advRun);

    // ---- TruthCert sign-and-download ----
    async function signAndDownload(envelope, caseName) {
      const key = (document.getElementById('truthcert-key').value || '').trim();
      if (key.length < 32) {
        alert('Set a TruthCert key (32+ chars) in the footer first.');
        return;
      }
      if (!window.PYODIDE_READY) {
        alert('Engine not ready yet.'); return;
      }
      window.PYODIDE.globals.set('SIG_PAYLOAD', window.PYODIDE.toPy(envelope));
      window.PYODIDE.globals.set('SIG_KEY', key);
      const bundle_json = await window.PYODIDE.runPythonAsync(`
import json, os
os.environ['TRUTHCERT_HMAC_KEY'] = SIG_KEY
from impossible_ma.truthcert import sign_bundle
bundle = sign_bundle(SIG_PAYLOAD.to_py())
json.dumps(bundle, default=float)
      `);
      const blob = new Blob([bundle_json], { type: 'application/json' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `impossibleMA_${caseName}_${Date.now()}.json`;
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(a.href);
    }

    document.getElementById('k1-export-json').addEventListener('click',
      () => signAndDownload(window.K1_LAST_ENVELOPE, 'k1'));
    document.getElementById('ms-export-json').addEventListener('click',
      () => signAndDownload(window.MS_LAST_ENVELOPE, 'missing_se'));
    document.getElementById('adv-export-json').addEventListener('click',
      () => signAndDownload(window.ADV_LAST_ENVELOPE, 'adversarial'));

    bootstrap();
  </script>
</body>
</html>
